# pm-os environment variables
#
# Copy this file to .env.local for development, or set these in your host's
# environment (Netlify, Vercel, Fly, Render, etc.) for production.
#
# Set at least ONE provider key. Users will only see providers whose keys are
# present.
#
# DO NOT commit .env.local or any file containing real keys. gitleaks runs in
# CI and will block PRs that contain secrets.

# Groq — fast, free tier — https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Ollama (local) — set to your Ollama server URL if not running on localhost
# OLLAMA_URL=http://localhost:11434

# Optional shared-secret auth for /api/ai.
# When set, every request to /api/ai must include the header
#   x-pm-os-token: <same value>
# If unset, /api/ai is open (fine for local dev or trusted internal hosts).
# Real per-user auth is tracked in issue #18.
# PM_OS_API_TOKEN=
